USDA_FOOD_DATA_API_KEY=your_usda_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
SECRET_KEY=generate-a-long-random-string-here
DATABASE_PATH=data/dictato.db
AI_DAILY_LIMIT=20
# Set to "true" when running behind HTTPS (Cloudflare Tunnel / Caddy)
SECURE_COOKIES=false
# Web Push (Phase 5). Generate a keypair with scripts/gen_vapid.py and paste here.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
FATSECRET_CLIENT_ID=your_fatsecret_client_id_here
FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret_here
# Local speech-to-text (faster-whisper): tiny/base/small/medium. Bigger = more
# accurate but slower on CPU; "small" is a good default. Downloads on first use.
WHISPER_MODEL=small
# Set to "false" to skip loading the Whisper model at startup.
WHISPER_WARMUP=true

# Comma-separated emails that can see the Admin usage dashboard (your own email).
ADMIN_EMAILS=you@example.com

# ── Swappable LLM backend (coach + voice/photo agent) ─────────────────────────
# Default 'anthropic' keeps native tool use, vision, and web-search on Claude.
# Set 'openai' to route the agent + coach through any OpenAI-compatible endpoint.
# (The nutrition web-lookup always stays on Anthropic — it needs server-side search.)
LLM_PROVIDER=anthropic
# For LLM_PROVIDER=openai — pick a backend:
#   OpenRouter (cloud):  LLM_BASE_URL=https://openrouter.ai/api/v1   LLM_API_KEY=sk-or-...
#   Local Ollama:        LLM_BASE_URL=http://localhost:11434/v1      LLM_API_KEY=ollama
LLM_BASE_URL=
LLM_API_KEY=
# Default model when provider=openai, e.g. deepseek/deepseek-chat, qwen/qwen-2.5-72b-instruct, gemma3
LLM_MODEL=
# Optional per-feature overrides (fall back to LLM_MODEL):
AGENT_MODEL=
COACH_MODEL=